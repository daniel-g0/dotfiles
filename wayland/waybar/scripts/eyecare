#!/usr/bin/env bash
# 20-20-20 eye care timer — outputs JSON for waybar (interval: 1)
# every 20 min: notify to look 20 ft away for 20 seconds

INTERVAL=1200
STATE_FILE="$HOME/.local/state/eyecare-start"

if [[ "$1" == "reset" ]]; then
    mkdir -p "$(dirname "$STATE_FILE")"
    date +%s > "$STATE_FILE"
    exit 0
fi

mkdir -p "$(dirname "$STATE_FILE")"
[[ -f "$STATE_FILE" ]] || date +%s > "$STATE_FILE"

start=$(cat "$STATE_FILE")
now=$(date +%s)
remaining=$(( INTERVAL - (now - start) ))

if (( remaining <= 0 )); then
    (
        flock -n 9 || exit 0
        # Re-read inside lock to avoid TOCTOU when multiple waybar instances race
        local_start=$(cat "$STATE_FILE")
        local_now=$(date +%s)
        if (( INTERVAL - (local_now - local_start) <= 0 )); then
            date +%s > "$STATE_FILE"
            notify-send -u normal -t 20000 "󰛐 Eye Break" "20-20-20: look 20 ft away for 20 seconds"
        fi
    ) 9>/tmp/eyecare-notify.lock
    remaining=$INTERVAL
fi

mins=$(( remaining / 60 ))
secs=$(( remaining % 60 ))
text=$(printf "󰛐 %02d:%02d" $mins $secs)

if (( remaining < 60 )); then
    class="critical"
elif (( remaining < 300 )); then
    class="warning"
else
    class="normal"
fi

printf '{"text":"%s","tooltip":"Eye break in %dm %02ds (20-20-20 rule). Click to reset.","class":"%s"}\n' \
    "$text" "$mins" "$secs" "$class"
