#!/usr/bin/env bash

VPN_DIR="$HOME/.config/vpns"

FZF_OPTS=(
    "--border=sharp"
    "--border-label= VPN Manager "
    "--cycle"
    "--height=~100%"
    "--highlight-line"
    "--info=inline-right"
    "--pointer="
    "--reverse"
    "--no-sort"
    "--ansi"
)

fzf_pick() {
    local label="$1"; shift
    fzf "${FZF_OPTS[@]}" --border-label=" $label " "$@"
}

strip_ansi() { sed 's/\x1b\[[0-9;]*m//g' | tr -s ' ' | sed 's/^ //;s/ $//'; }

is_connected() { pgrep -x vpnc > /dev/null 2>&1; }

status_line() {
    if is_connected; then
        local ip; ip=$(ip addr show tun0 2>/dev/null | awk '/inet /{print $2}')
        echo -e "\e[32m● Connected${ip:+  —  $ip}\e[0m"
    else
        echo -e "\e[90m○ Disconnected\e[0m"
    fi
}

# ── Detect VPN config type ────────────────────────────────────────────────────
detect_type() {
    local file="$1"
    case "${file##*.}" in
        pcf)  echo "cisco_pcf"; return ;;
        ovpn) echo "openvpn";   return ;;
    esac
    if grep -q "^\[main\]" "$file" 2>/dev/null && grep -q "^Host=" "$file" 2>/dev/null; then
        echo "cisco_pcf"
    elif grep -q "IPSec gateway" "$file" 2>/dev/null; then
        echo "vpnc_native"
    elif grep -q "^remote " "$file" 2>/dev/null; then
        echo "openvpn"
    else
        echo "unknown"
    fi
}

# ── Import ────────────────────────────────────────────────────────────────────
import_menu() {
    local search_dirs=("$HOME/Downloads" "$HOME/Documents" "$HOME/Desktop" "$HOME")
    local file
    file=$(find "${search_dirs[@]}" -maxdepth 3 \
        \( -name "*.pcf" -o -name "*.ovpn" -o -name "*.conf" \) \
        ! -path "$VPN_DIR/*" 2>/dev/null | sort -u \
        | fzf_pick "Import" --header="Select a VPN config  (.pcf  .ovpn  .conf)")
    [[ -z "$file" ]] && return

    local type; type=$(detect_type "$file")
    local name; name=$(basename "${file%.*}")
    local dest="$VPN_DIR/$name.conf"

    echo -e "Type detected: \e[1m$type\e[0m"
    echo

    case "$type" in
        cisco_pcf)
            grep -q "^Description=$" "$file" && sed -i "s/^Description=$/Description=$name/" "$file"
            pcf2vpnc "$file" "$dest"
            chmod 600 "$dest"
            echo "Imported (Cisco PCF → vpnc)  →  $dest"
            ;;
        vpnc_native)
            cp "$file" "$dest"
            chmod 600 "$dest"
            echo "Imported (vpnc native)  →  $dest"
            ;;
        openvpn)
            echo "OpenVPN config — not supported by vpnc."
            echo "Use: sudo openvpn \"$file\""
            ;;
        *)
            echo "Unknown format — cannot import."
            ;;
    esac

    echo
    read -rp "Press Enter to continue..."
}

# ── Connections submenu ───────────────────────────────────────────────────────
connections_menu() {
    while true; do
        local confs=()
        while IFS= read -r f; do confs+=("$f"); done < <(find "$VPN_DIR" -name "*.conf" 2>/dev/null | sort)

        if [[ ${#confs[@]} -eq 0 ]]; then
            echo "No configs in $VPN_DIR"; read -rp "Press Enter..."; return
        fi

        local raw
        raw=$(for f in "${confs[@]}"; do
            local n; n=$(basename "$f" .conf)
            local gw; gw=$(awk '/IPSec gateway/{print $3}' "$f" 2>/dev/null)
            echo -e "\e[1m$n\e[0m  \e[2m${gw}\e[0m"
        done | fzf_pick "Connections" --header="Select a connection")
        [[ -z "$raw" ]] && return

        local name; name=$(echo "$raw" | strip_ansi | awk '{print $1}')
        local conf="$VPN_DIR/$name.conf"
        [[ ! -f "$conf" ]] && echo "Config not found: $conf" && read -rp "Press Enter..." && continue

        local action
        action=$(printf '%b\n' \
            "\e[38;2;158;206;106m󰦝  Connect\e[0m" \
            "\e[38;2;125;207;255m  Edit\e[0m" \
            "\e[38;2;247;118;142m  Remove\e[0m" \
            | fzf_pick "$name")
        [[ -z "$action" ]] && continue

        local plain; plain=$(echo "$action" | strip_ansi)

        case "$plain" in
            *"Connect"*)
                sudo vpnc --enable-weak-authentication "$conf"
                echo; read -rp "Press Enter to continue..."
                ;;
            *"Edit"*)
                nvim "$conf"
                ;;
            *"Remove"*)
                read -rp "Remove $name? [y/N] " confirm
                [[ "$confirm" == [yY] ]] && rm "$conf" && echo "Removed."
                read -rp "Press Enter to continue..."
                ;;
        esac
    done
}

# ── Main menu ─────────────────────────────────────────────────────────────────
while true; do
    CHOICE=$(
        {
            is_connected && echo -e "\e[38;2;247;118;142m󰖃  Disconnect\e[0m"
            echo -e "\e[38;2;122;162;247m󰦝  Connections\e[0m"
            echo -e "\e[38;2;187;154;247m  Import\e[0m"
        } | fzf_pick "VPN Manager" --header="$(status_line)"
    )
    [[ -z "$CHOICE" ]] && exit 0

    plain=$(echo "$CHOICE" | strip_ansi)

    case "$plain" in
        *"Disconnect"*)
            sudo vpnc-disconnect
            echo; read -rp "Press Enter to continue..."
            ;;
        *"Connections"*)
            connections_menu
            ;;
        *"Import"*)
            import_menu
            ;;
    esac
done
