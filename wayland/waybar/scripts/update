#!/usr/bin/env bash
#
# NixOS flake update checker for waybar
# Module mode: shows days since last flake update
# Interactive mode: runs nix flake update then nixos-rebuild switch
#
# Requires: nix, jq, systemd (for notifications)

FLAKE_DIR="/home/user/Projects/personal/dotfiles"
LOCK_FILE="$FLAKE_DIR/flake.lock"

FG_BLUE="\e[34m"
FG_GREEN="\e[32m"
FG_RESET="\e[39m"

printf() {
	command printf "$@" >&2
}

get_days_since_update() {
	if [[ ! -f $LOCK_FILE ]]; then
		echo 0
		return
	fi

	local last_modified
	last_modified=$(jq -r '.nodes.nixpkgs.locked.lastModified // 0' "$LOCK_FILE" 2>/dev/null)

	if [[ $last_modified == 0 ]]; then
		echo 0
		return
	fi

	local now
	now=$(date +%s)
	echo $(( (now - last_modified) / 86400 ))
}

display_module() {
	local days
	days=$(get_days_since_update)

	local icon tooltip

	if ((days == 0)); then
		icon='󰸟'
		tooltip="Flake lock age unknown"
	elif ((days < 7)); then
		icon='󰸟'
		tooltip="Flake updated $days day(s) ago"
	elif ((days < 30)); then
		icon='󰄠'
		tooltip="Flake is $days days old — consider updating"
	else
		icon='󰒑'
		tooltip="Flake is $days days old — update recommended"
	fi

	cat <<- EOF
		{ "text": "$icon", "tooltip": "$tooltip" }
	EOF
}

do_update() {
	trap "pkill -RTMIN+1 waybar" EXIT

	printf "%bUpdating flake inputs...%b\n" "$FG_BLUE" "$FG_RESET"
	nix flake update --flake "$FLAKE_DIR"

	printf "\n%bRebuilding NixOS...%b\n" "$FG_BLUE" "$FG_RESET"
	sudo nixos-rebuild switch --flake "$FLAKE_DIR"

	notify-send "NixOS Update Complete" -i "package-install"
	printf "\n%bDone!%b\n" "$FG_GREEN" "$FG_RESET"
	read -rsn 1 -p "Press any key to exit..."
}

main() {
	case $1 in
		module)
			display_module
			;;
		*)
			do_update
			;;
	esac
}

main "$@"
