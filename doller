#!/usr/bin/env bash
# doller вҖ” dotfile installer
set -euo pipefail

# в”Җв”Җ Tokyo Night palette в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RS='\033[0m'; BD='\033[1m'
RED='\033[38;2;247;118;142m'
YLW='\033[38;2;224;175;104m'
GRN='\033[38;2;158;206;106m'
CYN='\033[38;2;125;207;255m'
BLU='\033[38;2;122;162;247m'
PRP='\033[38;2;187;154;247m'
FG='\033[38;2;192;202;245m'
DIM='\033[38;2;86;95;137m'

DOTS="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DRY=0; FORCE=0

for arg in "$@"; do
    case "$arg" in
        --dry-run|-n) DRY=1 ;;
        --force|-y)   FORCE=1 ;;
        --help|-h)
            echo "Usage: doller [--dry-run|-n] [--force|-y]"
            exit 0 ;;
    esac
done

# в”Җв”Җ Header в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header() {
    clear
    echo
    local logo=(
        'в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—     в–Ҳв–Ҳв•—     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— '
        'в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—'
        'в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ'
        'в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—'
        'в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘'
        'в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ'
    )
    local cols; cols=$(tput cols 2>/dev/null || echo 80)
    local logo_w=51
    local pad=$(( (cols - logo_w) / 2 ))
    echo -e "${PRP}${BD}"
    for line in "${logo[@]}"; do printf "%${pad}s%s\n" "" "$line"; done
    echo -e "${RS}"
    local sub="dotfile installer  В·  ${DOTS}"
    local sub_w=${#sub}
    local sub_pad=$(( (cols - sub_w) / 2 ))
    echo -e "${DIM}$(printf "%${sub_pad}s" "")${sub}${RS}"
    echo
}

# в”Җв”Җ OS detection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
detect_os() {
    if command -v nixos-rebuild &>/dev/null; then echo "nixos"
    elif [[ "$(uname)" == "Darwin" ]];       then echo "macos"
    elif grep -qi microsoft /proc/version 2>/dev/null; then echo "wsl"
    else echo "linux"
    fi
}

# в”Җв”Җ Symlink map: "repo_path|destination|os_filter" в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# os_filter: all | linux | nixos | macos  (linux applies to nixos+wsl too)
ALL_LINK_DEFS=(
    "nushell|$HOME/.config/nushell|all"
    "nvim|$HOME/.config/nvim|all"
    "starship/starship.toml|$HOME/.config/starship.toml|all"
    "kitty|$HOME/.config/kitty|all"
    "wallpapers|$HOME/.config/wallpapers|all"
    "fastfetch|$HOME/.config/fastfetch|all"
    "cursor|$HOME/.config/cursors|linux"
    "jiffy|$HOME/.config/jiffy|linux"
    "wallrizz|$HOME/.config/WallRizz|linux"
    "wayland/hypr|$HOME/.config/hypr|linux"
    "wayland/waybar|$HOME/.config/waybar|linux"
    "wayland/swaync|$HOME/.config/swaync|linux"
    "nixos/configuration.nix|/etc/nixos/configuration.nix|nixos"
)

link_applies() {
    local filter="$1" os="$2"
    case "$filter" in
        all)   return 0 ;;
        linux) [[ "$os" == "linux" || "$os" == "nixos" || "$os" == "wsl" ]] && return 0 ;;
        nixos) [[ "$os" == "nixos" ]] && return 0 ;;
        macos) [[ "$os" == "macos" ]] && return 0 ;;
    esac
    return 1
}

needs_sudo() { [[ "$1" == "nixos" ]]; }

# в”Җв”Җ Check a single symlink в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
check() {
    local src="$DOTS/$1" dst="$2"
    [[ ! -e "$src" ]]  && echo "no_source" && return
    if [[ -L "$dst" ]]; then
        [[ "$(readlink "$dst")" == "$src" ]] && echo "ok" || echo "conflict"
    elif [[ -e "$dst" ]]; then echo "conflict"
    else echo "will_link"
    fi
}

# в”Җв”Җ Status table в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
print_table() {
    local os="$1" current_section=""
    printf "    ${DIM}%-32s %-34s %s${RS}\n" "Source" "Destination" "Status"
    echo -e "    ${DIM}$(printf 'в”Җ%.0s' {1..72})${RS}"

    for entry in "${ALL_LINK_DEFS[@]}"; do
        IFS='|' read -r src dst filter <<< "$entry"
        link_applies "$filter" "$os" || continue

        if   [[ "$filter" == "all"   && "$current_section" != "all"   ]]; then
            echo -e "    ${DIM}Universal${RS}"; current_section="all"
        elif [[ "$filter" == "linux" && "$current_section" != "linux" ]]; then
            echo -e "\n    ${DIM}Linux / Wayland${RS}"; current_section="linux"
        elif [[ "$filter" == "nixos" && "$current_section" != "nixos" ]]; then
            echo -e "\n    ${PRP}NixOS system (sudo)${RS}"; current_section="nixos"
        elif [[ "$filter" == "macos" && "$current_section" != "macos" ]]; then
            echo -e "\n    ${BLU}macOS${RS}"; current_section="macos"
        fi

        local st; st="$(check "$src" "$dst")"
        local sdst="${dst/$HOME/\~}"
        needs_sudo "$filter" && sdst="[sudo] $sdst"

        case "$st" in
            ok)        printf "    ${DIM}%-32s %-34s ${GRN}вң“ linked${RS}\n"       "$src" "$sdst" ;;
            will_link) printf "    %-32s %-34s ${CYN}+ will link${RS}\n"          "$src" "$sdst" ;;
            conflict)  printf "    %-32s %-34s ${YLW}! conflict вҶ’ .bak${RS}\n"   "$src" "$sdst" ;;
            no_source) printf "    ${DIM}%-32s %-34s ? no source${RS}\n"          "$src" "$sdst" ;;
        esac
    done
}

# в”Җв”Җ Apply в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
apply_all() {
    local os="$1" ok=0 new=0 failed=0

    for entry in "${ALL_LINK_DEFS[@]}"; do
        IFS='|' read -r src dst filter <<< "$entry"
        link_applies "$filter" "$os" || continue

        local st; st="$(check "$src" "$dst")"
        [[ "$st" == "no_source" ]] && continue
        if [[ "$st" == "ok" ]]; then (( ok++ )); continue; fi

        local use_sudo=0; needs_sudo "$filter" && use_sudo=1
        local full_src="$DOTS/$src"
        local parent; parent="$(dirname "$dst")"
        if (( use_sudo )); then sudo mkdir -p "$parent"; else mkdir -p "$parent"; fi

        if [[ "$st" == "conflict" ]]; then
            local bak="${dst}.bak.$(date +%s)"
            if (( use_sudo )); then sudo mv "$dst" "$bak"; else mv "$dst" "$bak"; fi
            echo -e "    ${YLW}вҶ¶${RS} ${DIM}backed up $(basename "$dst") вҶ’ .bak${RS}"
        fi

        if (( use_sudo )); then sudo ln -sfn "$full_src" "$dst" && r=0 || r=1
        else ln -sfn "$full_src" "$dst" && r=0 || r=1; fi

        local sdst="${dst/$HOME/\~}"
        if (( r == 0 )); then
            echo -e "    ${GRN}вң“${RS} ${FG}$src${RS} ${DIM}вҶ’${RS} ${CYN}$sdst${RS}"
            (( new++ ))
        else
            echo -e "    ${RED}вң—${RS} failed: $dst"
            (( failed++ ))
        fi
    done

    echo
    echo -e "    ${GRN}${ok} already linked${RS}  ${CYN}${new} created${RS}  ${RED}${failed} failed${RS}"
}

# в”Җв”Җ Main в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header

OS="$(detect_os)"
echo -e "    ${DIM}OS:${RS} ${BLU}${OS}${RS}"
echo

echo -e "    ${BD}${FG}Symlink status${RS}"
echo
print_table "$OS"
echo

[[ "$DRY" == "1" ]] && echo -e "    ${DIM}Dry run вҖ” nothing changed.${RS}\n" && exit 0

if [[ "$FORCE" != "1" ]]; then
    echo -ne "    ${BD}Apply?${RS} ${DIM}[Y/n]${RS} "
    read -r confirm; confirm="${confirm:-y}"
    [[ "${confirm,,}" != "y" ]] && echo -e "\n    ${DIM}Aborted.${RS}\n" && exit 0
fi

echo
echo -e "    ${BD}${FG}LinkingвҖҰ${RS}"
echo
apply_all "$OS"

echo
echo -e "    ${BD}${GRN}Done!${RS}"
[[ "$OS" == "nixos" ]] && echo -e "    ${DIM}Run ${RS}${CYN}nixos-re-sw${RS}${DIM} to rebuild.${RS}"
echo
