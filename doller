#!/usr/bin/env bash
# doller вҖ” dotfile installer  (bash 3.2+ compatible)
set -euo pipefail

# в”Җв”Җ Tokyo Night palette в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RS='\033[0m'; BD='\033[1m'
RED='\033[38;2;247;118;142m'
YLW='\033[38;2;224;175;104m'
GRN='\033[38;2;158;206;106m'
CYN='\033[38;2;125;207;255m'
BLU='\033[38;2;122;162;247m'
PRP='\033[38;2;187;154;247m'
FG='\033[38;2;192;202;245m'
DIM='\033[38;2;86;95;137m'

DOTS="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DRY=0; FORCE=0

for arg in "$@"; do
    case "$arg" in
        --dry-run|-n) DRY=1 ;;
        --force|-y)   FORCE=1 ;;
        --help|-h) printf "Usage: doller [--dry-run|-n] [--force|-y]\n"; exit 0 ;;
    esac
done

# в”Җв”Җ Terminal width helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
COLS=$(tput cols 2>/dev/null || printf "80")
# pad string to terminal center
center() {
    local str="$1" len="${#1}"
    local pad=$(( (COLS - len) / 2 ))
    printf "%${pad}s%s\n" "" "$str"
}
# horizontal rule of given char
rule() {
    local char="${1:-в”Җ}" n="${2:-$COLS}"
    printf '%*s' "$n" '' | tr ' ' "$char"
}

# в”Җв”Җ Header в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header() {
    clear
    echo

    # Logo lines вҖ” 52 chars wide
    local logo=(
        "в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—     в–Ҳв–Ҳв•—     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— "
        "в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—"
        "в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ"
        "в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—"
        "в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘"
        "в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ"
    )
    local logo_w=51
    local pad=$(( (COLS - logo_w) / 2 ))

    printf "${PRP}${BD}"
    for line in "${logo[@]}"; do
        printf "%${pad}s%s\n" "" "$line"
    done
    printf "${RS}\n"

    # Subtitle
    local sub="dotfile installer"
    local sub_pad=$(( (COLS - ${#sub}) / 2 ))
    printf "${DIM}%${sub_pad}s%s${RS}\n" "" "$sub"
    echo
}

# в”Җв”Җ Border box helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
BOX_W=72   # inner width (content between borders)

box_top() {
    local title="${1:-}"
    if [ -n "$title" ]; then
        local t=" ${title} "
        local left_dashes=$(( (BOX_W - ${#t}) / 2 ))
        local right_dashes=$(( BOX_W - left_dashes - ${#t} ))
        local pad=$(( (COLS - BOX_W - 2) / 2 ))
        printf "${DIM}%${pad}sв”Ң" ""
        printf '%*s' "$left_dashes" '' | tr ' ' 'в”Җ'
        printf "${RS}${BD}${FG}%s${RS}${DIM}" "$t"
        printf '%*s' "$right_dashes" '' | tr ' ' 'в”Җ'
        printf "в”җ${RS}\n"
    else
        local pad=$(( (COLS - BOX_W - 2) / 2 ))
        printf "${DIM}%${pad}sв”Ң" ""
        printf '%*s' "$BOX_W" '' | tr ' ' 'в”Җ'
        printf "в”җ${RS}\n"
    fi
}

box_bottom() {
    local pad=$(( (COLS - BOX_W - 2) / 2 ))
    printf "${DIM}%${pad}sв””" ""
    printf '%*s' "$BOX_W" '' | tr ' ' 'в”Җ'
    printf "в”ҳ${RS}\n"
}

box_sep() {
    local pad=$(( (COLS - BOX_W - 2) / 2 ))
    printf "${DIM}%${pad}sв”ң" ""
    printf '%*s' "$BOX_W" '' | tr ' ' 'в”Җ'
    printf "в”Ө${RS}\n"
}

box_row() {
    local content="$1"
    local pad=$(( (COLS - BOX_W - 2) / 2 ))
    printf "${DIM}%${pad}sв”Ӯ${RS}%s${DIM}в”Ӯ${RS}\n" "" "$content"
}

box_blank() {
    local pad=$(( (COLS - BOX_W - 2) / 2 ))
    printf "${DIM}%${pad}sв”Ӯ${RS}%${BOX_W}s${DIM}в”Ӯ${RS}\n" "" ""
}

# в”Җв”Җ OS detection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
detect_os() {
    if command -v nixos-rebuild >/dev/null 2>&1; then printf "nixos"
    elif [ "$(uname)" = "Darwin" ];               then printf "macos"
    elif grep -qi microsoft /proc/version 2>/dev/null; then printf "wsl"
    else printf "linux"
    fi
}

# в”Җв”Җ Symlink map: "repo_path|destination|os_filter" в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# os_filter: all | linux | nixos | macos | wsl
# linux also applies to nixos + wsl
ALL_LINK_DEFS=(
    "nushell|$HOME/.config/nushell|all"
    "nvim|$HOME/.config/nvim|all"
    "starship/starship.toml|$HOME/.config/starship.toml|all"
    "kitty|$HOME/.config/kitty|all"
    "wallpapers|$HOME/.config/wallpapers|all"
    "fastfetch|$HOME/.config/fastfetch|all"
    "cursor|$HOME/.config/cursors|linux"
    "jiffy|$HOME/.config/jiffy|linux"
    "wallrizz|$HOME/.config/WallRizz|linux"
    "wayland/hypr|$HOME/.config/hypr|linux"
    "wayland/waybar|$HOME/.config/waybar|linux"
    "wayland/swaync|$HOME/.config/swaync|linux"
    "nixos/configuration.nix|/etc/nixos/configuration.nix|nixos"
)

link_applies() {
    local filter="$1" os="$2"
    case "$filter" in
        all)   return 0 ;;
        linux) [ "$os" = "linux" ] || [ "$os" = "nixos" ] || [ "$os" = "wsl" ] && return 0 ;;
        nixos) [ "$os" = "nixos" ] && return 0 ;;
        macos) [ "$os" = "macos" ] && return 0 ;;
        wsl)   [ "$os" = "wsl" ]   && return 0 ;;
    esac
    return 1
}

needs_sudo() { [ "$1" = "nixos" ] && return 0; return 1; }

# в”Җв”Җ Check symlink status в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
check_link() {
    local src="$DOTS/$1" dst="$2"
    [ ! -e "$src" ] && printf "no_source" && return
    if [ -L "$dst" ]; then
        [ "$(readlink "$dst")" = "$src" ] && printf "ok" || printf "conflict"
    elif [ -e "$dst" ]; then printf "conflict"
    else printf "will_link"
    fi
}

# в”Җв”Җ Status table inside box в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
print_table() {
    local os="$1"
    local current_section=""

    # Column widths that fit BOX_W=72: src=28, dst=30, status=12 + 2 spaces
    local hdr
    hdr="$(printf " ${DIM}%-28s  %-30s  %s${RS}" "Source" "Destination" "Status")"
    box_row "$hdr"
    box_sep

    for entry in "${ALL_LINK_DEFS[@]}"; do
        IFS='|' read -r src dst filter <<< "$entry"
        link_applies "$filter" "$os" || continue

        # Section dividers
        if [ "$filter" = "all" ] && [ "$current_section" != "all" ]; then
            local sh; sh="$(printf " ${DIM}%-${BOX_W}s${RS}" "  Universal")"
            # trim to BOX_W
            box_row "$(printf " ${DIM}%-$((BOX_W-1))s${RS}" "  Universal")"
            current_section="all"
        elif [ "$filter" = "linux" ] && [ "$current_section" != "linux" ]; then
            box_sep
            box_row "$(printf " ${DIM}%-$((BOX_W-1))s${RS}" "  Linux / Wayland")"
            current_section="linux"
        elif [ "$filter" = "nixos" ] && [ "$current_section" != "nixos" ]; then
            box_sep
            box_row "$(printf " ${PRP}%-$((BOX_W-1))s${RS}" "  NixOS system  (sudo)")"
            current_section="nixos"
        elif [ "$filter" = "macos" ] && [ "$current_section" != "macos" ]; then
            box_sep
            box_row "$(printf " ${BLU}%-$((BOX_W-1))s${RS}" "  macOS")"
            current_section="macos"
        fi

        local st; st="$(check_link "$src" "$dst")"
        local sdst="${dst/$HOME/\~}"
        needs_sudo "$filter" && sdst="[sudo] ${sdst}"

        local row
        case "$st" in
            ok)
                row="$(printf " ${DIM}%-28s  %-30s  ${GRN}вң“ linked${RS}" "$src" "$sdst")"
                ;;
            will_link)
                row="$(printf " %-28s  %-30s  ${CYN}+ will link${RS}" "$src" "$sdst")"
                ;;
            conflict)
                row="$(printf " %-28s  %-30s  ${YLW}! conflict вҶ’ .bak${RS}" "$src" "$sdst")"
                ;;
            no_source)
                row="$(printf " ${DIM}%-28s  %-30s  ${DIM}? no source${RS}" "$src" "$sdst")"
                ;;
        esac
        box_row "$row"
    done
}

# в”Җв”Җ Apply links в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
apply_all() {
    local os="$1"
    local ok=0 new=0 failed=0

    for entry in "${ALL_LINK_DEFS[@]}"; do
        IFS='|' read -r src dst filter <<< "$entry"
        link_applies "$filter" "$os" || continue

        local st; st="$(check_link "$src" "$dst")"
        [ "$st" = "no_source" ] && continue
        if [ "$st" = "ok" ]; then ok=$((ok+1)); continue; fi

        local use_sudo=0
        needs_sudo "$filter" && use_sudo=1
        local full_src="$DOTS/$src"
        local parent; parent="$(dirname "$dst")"

        if [ "$use_sudo" = "1" ]; then sudo mkdir -p "$parent"
        else mkdir -p "$parent"; fi

        if [ "$st" = "conflict" ]; then
            local bak="${dst}.bak.$(date +%s)"
            if [ "$use_sudo" = "1" ]; then sudo mv "$dst" "$bak"
            else mv "$dst" "$bak"; fi
            box_row "$(printf " ${YLW}вҶ¶${RS} ${DIM}backed up %-20s вҶ’ .bak%$((BOX_W-44))s${RS}" "$(basename "$dst")" "")"
        fi

        if [ "$use_sudo" = "1" ]; then sudo ln -sfn "$full_src" "$dst" && r=0 || r=1
        else ln -sfn "$full_src" "$dst" && r=0 || r=1; fi

        local sdst="${dst/$HOME/\~}"
        if [ "$r" = "0" ]; then
            box_row "$(printf " ${GRN}вң“${RS} ${FG}%-28s${RS} ${DIM}вҶ’${RS} ${CYN}%-$((BOX_W-35))s${RS}" "$src" "$sdst")"
            new=$((new+1))
        else
            box_row "$(printf " ${RED}вң—${RS} failed: %-$((BOX_W-12))s" "$dst")"
            failed=$((failed+1))
        fi
    done

    box_sep
    box_row "$(printf "  ${GRN}%-2d already linked${RS}   ${CYN}%-2d created${RS}   ${RED}%-2d failed%$((BOX_W-42))s${RS}" \
        "$ok" "$new" "$failed" "")"
}

# в”Җв”Җ Main в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
header

OS="$(detect_os)"

box_top " Status "
box_blank
print_table "$OS"
box_blank
box_bottom

echo

[ "$DRY" = "1" ] && printf "  ${DIM}Dry run вҖ” nothing changed.${RS}\n\n" && exit 0

if [ "$FORCE" != "1" ]; then
    local_pad=$(( (COLS - 26) / 2 ))
    printf "%${local_pad}s${BD}Apply?${RS} ${DIM}[Y/n]${RS} " ""
    read -r confirm; confirm="${confirm:-y}"
    confirm="$(printf "%s" "$confirm" | tr '[:upper:]' '[:lower:]')"
    [ "$confirm" != "y" ] && printf "\n  ${DIM}Aborted.${RS}\n\n" && exit 0
fi

echo
box_top " Linking "
box_blank
apply_all "$OS"
box_blank
box_bottom

echo
local_pad=$(( (COLS - 5) / 2 ))
printf "${BD}${GRN}%${local_pad}sDone!${RS}\n" ""
[ "$OS" = "nixos" ] && printf "  ${DIM}Run ${RS}${CYN}nixos-re-sw${RS}${DIM} to rebuild.${RS}\n"
echo
